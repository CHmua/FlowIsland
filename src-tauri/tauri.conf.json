{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlowIsland",
  "version": "2.3.7",
  "identifier": "com.ryen.nsd",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "FlowIsland 控制台",
        "width": 960,
        "height": 640,
        "resizable": false,
        "decorations": false,
        "center": true,
        "maximized": false,
        "maximizable": false,
        "label": "main",
        "url": "/",
        "visible": false
      },
      {
        "title": "FlowIsland Widget",
        "width": 210,
        "height": 36,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "maximized": false,
        "maximizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "label": "widget",
        "url": "/widget"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/tools/LibreHardwareMonitor/": "tools/LibreHardwareMonitor/",
      "resources/tools/OpenHardwareMonitor/": "tools/OpenHardwareMonitor/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
